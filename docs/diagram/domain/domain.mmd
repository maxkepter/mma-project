classDiagram
    class User {
        -id: uuid
        -username: string
        -hashPassword: string
        -email: string
        -displayName: string
        -createAt: Date
        +checkPassword(hashPassword: string) boolean
        +updateProfile(displayName: string, email: string) void
    }

    class Gender {
        -Male
        -Female
    }

    <<Enumeration>> Gender

    namespace CoreData {
        class LotteryResult {
            -id: uuid
            -date: Date
            -source: string
            -region: string
            +addNumber(number: LotteryNumber) void
            +getNumbers() LotteryNumber[]
        }

        class LotteryNumber {
            -prizeLevel: prizeLevel
            -value: string
            -position: int
            +getTwoDigitNumber() string
            +getHeadTailNumber() string
        }

        class PrizeLevel {
            -Special
            -First
            -Second
            -Third
            -Fourth
            -Fifth
            -Sixth
            -Seventh
        }
    }

    <<AggregateRoot>> LotteryResult
    <<ValueObject>> LotteryNumber
    <<Enumeration>> PrizeLevel

    LotteryResult "1" *-- "*" LotteryNumber : contains
    LotteryNumber ..> PrizeLevel : uses

    namespace NewsModule {
        class NewsArticle {
            -id: uuid
            -title: string
            -summary: string
            -content: string
            -source: string
            -publishDate: Date
        }
        class Signal {
            -id: uuid
            -type: string
            -content: string
            -source: string
            -detectedAt: Date
            +evaluate() float
        }
        class DeathRecord {
            -id: uuid
            -name: string
            -age: int
            -gender: Gender
            -birthDate: Date
            -deathDate: Date
            -causeOfDeath: string
            -source: string
        }
    }

    DeathRecord ..> Gender : has

    namespace StrategyModule {
        class Strategy {
            -id: uuid
            -userId: uuid
            -name: string
            -description: string
            -createdAt: Date
            +addCondition(condition: StrategyCondition) void
            +runBacktest() BacktestRun
        }
        class StrategyCondition {
            -id: uuid
            -type: string
            -parameters: json
            +evaluate(result: LotteryResult) boolean
        }
        class BacktestRun {
            -id: uuid
            -strategyId: uuid
            -startDate: Date
            -endDate: Date
            -winRate: float
            -profit: float
            +execute() BacktestResult
        }
        class BacktestResult {
            -id: uuid
            -backtestRunId: uuid
            -totalBets: int
            -wonBets: int
            -lostBets: int
            -totalProfit: float
        }
    }

    <<AggregateRoot>> Strategy
    <<ValueObject>> StrategyCondition
    <<Entity>> BacktestRun
    <<ValueObject>> BacktestResult

    Strategy "1" *-- "*" StrategyCondition : defines
    Strategy "1" o-- "*" BacktestRun : executes
    BacktestRun "1" *-- "1" BacktestResult : yields
    User "1" --> "*" Strategy : owns


    namespace JournalModule {
        class BetEntry {
            -id: uuid
            -userId: uuid
            -number: string
            -amount: float
            -betDate: Date
            +updateStatus(status: BetStatus) void
        }
        class BetResult {
            -id: uuid
            -betId: uuid
            -actualNumber: string
            -isWin: boolean
            -payout: float
            +calculatePayout(amount: float) float
        }
        class BetStatus {
            -Pending
            -Won
            -Lost
        }
    }

    <<AggregateRoot>> BetEntry
    <<Entity>> BetResult
    <<Enumeration>> BetStatus

    BetResult "1" --* "*" BetEntry : belongs to
    BetEntry "*" --> "1" User : created by

    namespace AIModule {
        class AIInsight {
            -id: uuid
            -content: string
            -confidenceScore: float
            -createdAt: Date
        }
        class ChatConversation {
            -id: uuid
            -userId: uuid
            +addMessage(message: ChatMessage) void
        }
        class ChatMessage {
            -id: uuid
            -role: string
            -content: string
            -timestamp: Date
        }
    }

    <<AggregateRoot>> ChatConversation
    <<Entity>> ChatMessage

    ChatConversation "1" *-- "*" ChatMessage : contains
    ChatConversation "*" --> "1" User : created by

