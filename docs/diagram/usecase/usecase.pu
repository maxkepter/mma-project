@startuml
left to right direction

actor "User" as User

rectangle "LotoForge" {
    package "Statistics" {
        usecase "UC-01 Xem thống kê tần suất"
        usecase "UC-02 Xem thống kê số gan"
        usecase "UC-03 Xem thống kê lô rơi"
        usecase "UC-04 Xem thống kê đầu đuôi"
        usecase "UC-05 Xem thống kê cặp số"
        usecase "UC-06 Xem heatmap"
    }

    package "Analytics & Prediction" {
        usecase "UC-07 Phân tích xu hướng"
        usecase "UC-08 Phân tích chu kỳ"
        usecase "UC-09 Phân tích tương quan"
        usecase "UC-10 Xem dự báo"
        usecase "UC-11 Nhận phân tích AI"
    }

    package "Strategy Management" {
        usecase "UC-12 Quản lý chiến lược"
        usecase "UC-13 Xây dựng điều kiện"
        usecase "UC-14 Backtest chiến lược"
        usecase "UC-15 Phân tích backtest"
        usecase "UC-16 So sánh chiến lược"
        usecase "UC-17 Sinh chiến lược AI"
    }

    package "Betting Journal" {
        usecase "UC-18 Ghi nhật ký đánh"
        usecase "UC-19 Quản lý nhật ký đánh"
        usecase "UC-20 Theo dõi hiệu suất"
    }

    package "Knowledge Hub" {
        usecase "UC-21 Lưu tri thức"
    }

    package "News & Signals" {
        usecase "UC-24 Xem tin tức"
        usecase "UC-25 Xem tín hiệu"
    }

    package "AI Assistant" {
        usecase "UC-26 Trao đổi với AI"
        usecase "UC-27 Phân tích chiến lược AI"
        usecase "UC-28 Tạo báo cáo AI"
    }
}

User --> "UC-01 Xem thống kê tần suất"
