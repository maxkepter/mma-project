

# Backend API URL
# - Physical device (Expo Go) on same Wi-Fi: use your dev machine's LAN IP, e.g. http://192.168.2.44
# - Android emulator: use http://10.0.2.2
# - iOS simulator / Web: http://localhost works
EXPO_PUBLIC_API_URL=http://localhost
EXPO_PUBLIC_API_PORT=3000

# Dev-only flags (true = hien thi nut dev, false = an)
EXPO_PUBLIC_DEV_MODE=true
